    "@types/bcrypt": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "bcrypt": "^5.1.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^6.3.4",
